# OpenAI API credentials used for translating subtitles to Hebrew.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Leave empty to use the default OpenAI endpoint. Set this only if you use a
# proxy or an OpenAI-compatible alternative provider.
OPENAI_BASE_URL=

# OpenSubtitles REST API (https://www.opensubtitles.com/) credentials.
# An API key is required. Username/password are optional but raise your
# daily download quota.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# TMDB API key used only for metadata lookup:
# series title, episode title, and episode IMDb ID fallback.
TMDB_API_KEY=

# Local server port.
PORT=7000

# Public base URL used to build subtitle file URLs returned to Stremio.
# Local example:  http://127.0.0.1:7000
# Render example: https://your-addon.onrender.com
PUBLIC_BASE_URL=http://127.0.0.1:7000
